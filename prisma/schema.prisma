generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String        @id @default(cuid())
  firstName    String
  lastName     String
  email        String        @unique
  password     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  sessions     Session[]
  userProjects UserProject[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Project {
  id           String        @id @default(cuid())
  name         String        @default("Mon Chantier")
  description  String?
  accessCode   String        @default("1234")
  startDate    DateTime?
  endDate      DateTime?
  address      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  userProjects UserProject[]
  events       Event[]
  requests     Request[]
  documents    Document[]
  tasks        Task[]
  activities   Activity[]
  constraints  Constraint[]
}

model UserProject {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role      String   @default("member")
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String
  date        DateTime @default(now())
  author      String
  priority    String   @default("normale")
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([category])
  @@index([projectId])
}

model Request {
  id          String    @id @default(cuid())
  title       String
  description String?
  type        String
  status      String    @default("en_attente")
  author      String
  assignedTo  String?
  dueDate     DateTime?
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  comments    Comment[]

  @@index([status])
  @@index([projectId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  author    String
  requestId String
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([requestId])
}

model Document {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String
  filePath    String
  fileName    String
  fileSize    Int
  mimeType    String
  author      String
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([projectId])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("a_faire")
  priority    String    @default("normale")
  assignedTo  String?
  dueDate     DateTime?
  author      String
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([priority])
  @@index([projectId])
}

model Activity {
  id          String   @id @default(cuid())
  type        String
  description String
  author      String
  entityType  String
  entityId    String?
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([entityType])
  @@index([projectId])
}

model Constraint {
  id             String    @id @default(cuid())
  title          String
  description    String?
  type           String
  status         String    @default("active")
  dueDate        DateTime?
  penaltyAmount  Float?
  penaltyUnit    String?
  penaltyDetails String?
  responsible    String?
  author         String
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([dueDate])
}
